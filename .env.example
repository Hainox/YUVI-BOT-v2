# --- Telegram ---
BOT_TOKEN=replace_me
CHAT_ID=-1000000000000

# --- Database / Cache ---
DATABASE_URL=postgresql+asyncpg://yuvi:yuvi@postgres:5432/yuvi
REDIS_URL=redis://redis:6379/0

# --- Backfill (личный аккаунт, НЕ бот) ---
# TG_API_ID и TG_API_HASH — креды ЛИЧНОГО Telegram-аккаунта (получаются на
# https://my.telegram.org), нужны только для backfill истории через Pyrogram/
# Kurigram userbot. Это НЕ токен бота (BOT_TOKEN выше) — не путать.
# Опциональны: без них бот стартует нормально, просто backfill будет недоступен.
TG_API_ID=
TG_API_HASH=

# --- AI provider (OpenAI-compatible) ---
OPENAI_BASE_URL=https://opencode.ai/zen/go/v1
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini

# --- Bot runtime ---
TZ=Europe/Moscow
LOG_LEVEL=INFO

# --- API / NLP URLs ---
API_HOST=0.0.0.0
API_PORT=8000
NLP_HOST=0.0.0.0
NLP_PORT=8000
NLP_SENTIMENT_MODEL=seara/rubert-tiny2-russian-sentiment
NLP_TOXICITY_MODEL=cointegrated/rubert-tiny-toxicity

# --- Mini App ---
MINIAPP_API_BASE_URL=/api/v1
MINIAPP_DEEPLINK=

